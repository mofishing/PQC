    {
      "id": "ALG.RSA.PKE",
      "algorithm_family": "RSA",
      "category": "asymmetric",
      "quantum_secure": false,
      "status_zh": "不安全",
      "q_security_bits": 0,
      "params": {
        "key_bits": {
          "allow": [4096, 8192],
          "default": 4096,
          "severity_if_not_allow": "high"
        },
        "padding": {
          "allow": ["OAEP"],
          "default": "OAEP",
          "severity_if_not_allow": "medium"
        }
      },
      "reason": "RSA 基于整数分解，被 Shor 算法在容错量子机上破解（0 位）。",
      "recommendation": "使用 Kyber 等 PQC KEM 或 RSA+Kyber 混合 KEM。"
    },
    {
      "id": "ALG.SM2.PKE",
      "algorithm_family": "SM2 (Public-Key Encryption)",
      "category": "asymmetric",
      "quantum_secure": false,
      "status_zh": "不安全（量子下）",
      "q_security_bits": 0,
      "params": {
        "mode": {
          "allow": ["C1C3C2"],
          "default": "C1C3C2",
          "severity_if_not_allow": "low"
        }
      },
      "reason": "SM2 属于 ECC 体制，量子下不安全；同时 C1C2C3 模式完整性更弱。",
      "recommendation": "优先 C1C3C2；中长期迁移到 PQC KEM（如 Kyber）或混合方案。"
    },
    {
      "id": "ALG.SM9.PKE",
      "algorithm_family": "SM9 (Identity-Based Encryption)",
      "category": "asymmetric",
      "quantum_secure": false,
      "status_zh": "不安全（量子下）",
      "q_security_bits": 0,
      "params": {
        "role": {
          "allow": ["IBE", "KEM"],
          "default": "IBE",
          "severity_if_not_allow": "low"
        }
      },
      "reason": "SM9 基于椭圆曲线上的双线性对，安全性依赖离散对数与相关假设。量子计算下这些假设失效（Shor）。",
      "recommendation": "中长期应迁移到 PQC KEM（如 Kyber）或 SM9+PQC 的混合方案；新系统避免将 SM9 作为唯一长期机密性保障。"
    },
    {
      "id": "ALG.ZUC",
      "algorithm_family": "ZUC (Zhongchongzhi Stream Cipher)",
      "category": "symmetric",
      "quantum_secure": "weak",
      "status_zh": "不安全（量子下 64 位）",
      "q_security_bits": 64,
      "params": {
        "key_bits": {
          "allow": [128],
          "default": 128,
          "severity_if_not_allow": "medium"
        }
      },
      "reason": "ZUC 是移动通信中的 128 位流密码。Grover 模型下穷举复杂度平方根下降，等效强度约 64 位，不满足高强度 PQ 要求。",
      "recommendation": "在通信协议中更关键的是整体方案（含 KDF/KEM）。如向 PQ 迁移，可通过在密钥协商层引入 Kyber/Classic McEliece 等 PQC，同时逐步减少对 128 bit 流密码的长期机密性依赖。"
    },
